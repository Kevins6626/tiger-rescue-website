---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';

const {
  title = 'Artifacts',
  id,
} = Astro.props;

const artifacts = [
  {
    title: 'Development Methodology',
    description: 'Outlines planned project artifacts and activities, team roles and responsibilities, and the metrics and measurements used to track progress.',
    pdf: '/artifacts/Development-Methodology.pdf',
  },
  {
    title: 'Domain Model',
    description: 'Defines the core concepts, entities, and relationships within the Tiger Rescue system domain.',
    pdf: '/artifacts/tf_domain_model.png',
  },
  {
    title: 'Tools & Techniques',
    description: 'Documents the software tools, frameworks, and development techniques used throughout the project.',
    pdf: '/artifacts/Synopsis_Roles_Keywords_and_Tools_Techniques.pdf',
  },
  {
    title: 'Metrics & Measurements',
    description: 'Defines the quantitative and qualitative metrics used to evaluate project progress and system performance.',
    pdf: '/artifacts/Metrics-&-Measurements.pdf',
  },
  {
    title: 'Final Plan',
    description: 'Consolidates the full project plan including timeline, milestones, deliverables, and team responsibilities.',
    pdf: '/artifacts/Final-Plan.pdf',
  },
  {
    title: 'Pre-Flight Checklist',
    description: 'Checklist used prior to test flights to ensure drone hardware, software, and safety conditions are verified before deployment.',
    pdf: '/artifacts/Preflight-Checklist-and-Execution-Guide.pdf',
  },
  {
    title: 'Intern Recruitment',
    description: 'Outlines the project background, intern responsibilities, recommended technical familiarity, and a structured process plan for onboarding a potential intern.',
    pdf: '/artifacts/Intern_Recruitment.pdf',
  },
  {
    title: 'Final Fall Presentation',
    description: 'Slide deck presented at the end of the fall semester summarizing project progress, design decisions, and next steps.',
    pdf: '/artifacts/Tiger_Rescue_Final_Fall_Presentation.pdf',
  },
  {
    title: 'Final Spring Presentation',
    description: "Slide deck presented at the end of the spring semester showcasing the system's core features, architecture, and live demonstration.",
    pdf: '/artifacts/Tiger_Rescue_Final_Spring_Presentation.pdf',
  },
];
---

<WidgetWrapper containerClass="max-w-4xl mx-auto">
  <Headline
    title="Project Artifacts"
    subtitle="All project documentation in one place. Click any document to expand."
    tagline="Tiger Rescue"
  />

  <div class="flex flex-col">
    {artifacts.map((doc, i) => (
      <div class="accordion-item border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden mb-2 transition-colors duration-200">

        <div class="flex items-center justify-between px-6 py-4 bg-white dark:bg-slate-900 hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors duration-150">
          <button
            class="accordion-trigger flex items-center gap-4 flex-1 min-w-0 text-left"
            aria-expanded="false"
            aria-controls={`panel-${i}`}
          >
            <span class="text-xs font-medium text-primary tabular-nums flex-shrink-0">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex flex-col gap-0.5 min-w-0">
              <span class="text-base font-semibold text-gray-900 dark:text-white">{doc.title}</span>
              <span class="text-sm text-muted hidden sm:block">{doc.description}</span>
            </div>
          </button>

          <div class="flex items-center gap-3 flex-shrink-0">
            <a
              href={doc.pdf}
              target="_blank"
              rel="noopener noreferrer"
              class="hidden sm:inline-flex items-center text-xs font-medium text-primary border border-primary rounded px-3 py-1.5 hover:bg-primary hover:text-white transition-colors duration-150 whitespace-nowrap"
            >
              Open ↗
            </a>
            <button
              class="accordion-chevron-btn flex items-center text-muted"
              aria-controls={`panel-${i}`}
            >
              <span class="chevron transition-transform duration-300">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
          </div>
        </div>

        <div class="accordion-panel grid" style="grid-template-rows: 0fr;" id={`panel-${i}`} role="region">
          <div class="overflow-hidden">
            <iframe
              src={doc.pdf}
              class="block w-full h-[800px] border-t border-gray-200 dark:border-gray-700"
              loading="lazy"
              title={doc.title}
            ></iframe>
          </div>
        </div>

      </div>
    ))}
  </div>
</WidgetWrapper>

<style>
  .accordion-item.is-open {
    @apply border-primary;
  }

  .accordion-item.is-open .chevron {
    transform: rotate(180deg);
    @apply text-primary;
  }

  .accordion-panel {
    transition: grid-template-rows 0.35s ease;
  }

  .accordion-panel.is-open {
    grid-template-rows: 1fr !important;
  }

  @media (max-width: 640px) {
    iframe {
      height: 500px;
    }
  }
</style>

<script lang="ts">
  function init(){
    const items = document.querySelectorAll('.accordion-item');

    items.forEach((item) => {
    const trigger = item.querySelector('.accordion-trigger');
    const chevronBtn = item.querySelector('.accordion-chevron-btn');
    const panel = item.querySelector('.accordion-panel');

    const toggle = () => {
      const isOpen = item.classList.contains('is-open');

      // Close all
      items.forEach((el) => {
        el.classList.remove('is-open');
        el.querySelector('.accordion-panel')?.classList.remove('is-open');
        el.querySelector('.accordion-trigger')?.setAttribute('aria-expanded', 'false');
      });

      // Open clicked if it was closed
      if (!isOpen) {
        item.classList.add('is-open');
        panel?.classList.add('is-open');
        trigger?.setAttribute('aria-expanded', 'true');
      }
    };

    trigger?.addEventListener('click', toggle);
    chevronBtn?.addEventListener('click', toggle);
  });
  }
  
  document.addEventListener('astro:page-load', init);
</script>
---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import TigerRescueHero from '~/components/widgets/TigerRescueHero.astro';
import Content from '~/components/widgets/Content.astro';
import { getPermalink } from '~/utils/permalinks';
import Team from '~/components/widgets/Team.astro';
import Timetracking from '~/components/widgets/Timetracking.astro';

import bae_building from '~/assets/images/bae_building.png';
import default_profile from '~/assets/images/default_profile.png';
// import aiden_k from '~/assets/images/aiden_k.png';
import kevin_s from '~/assets/images/kevin_s.png';
// import dan_c from '~/assets/images/dan_c.png';
import mason_b from '~/assets/images/mason_b.png';

const metadata = {
  title: 'Tiger Rescue 2: Electric Boogaloo',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'About', href: '#about' },
        { text: 'Team Roles', href: '#roles' },
        { text: 'Sponsor', href: '#sponsor' },
        { text: 'Time Tracking', href: '#timetracking' },
        { text: 'Artifacts', href: getPermalink('/artifacts') },
      ]}
      isSticky
      hasVideo
      showToggleTheme
    />
  </Fragment>

  <!-- Hero2 Widget ******************* -->

  <TigerRescueHero
    id="hero"
    title="Tiger Rescue"
    tagline="RIT Software Engineering Senior Project (Fall 2025 - Spring 2026)"
    class:list={'h-[1000px]'}
    actions={[{ variant: 'primary', text: 'Learn more', href: getPermalink('/#about') }]}
    videoSrc = "ml_video.mp4"
  >
    <Fragment slot="subtitle"> Saving dogs one flight at a time. </Fragment>
  </TigerRescueHero>

  <!-- Content Widget **************** -->

<div id="about" class="relative">
  <!-- BACKGROUND -->
  <div class="absolute inset-0 bg-blue-50 dark:opacity-5"></div>

  <div class="relative px-6 py-16 max-w-7xl mx-auto">
    <!-- CENTERED HEADING -->
    <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-10 text-center">
      Project Synopsis
    </h2>

    <!-- TWO COLUMN LAYOUT -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
      <!-- VIDEO (left, since original was isReversed) -->
      <div class="w-full overflow-hidden rounded-xl shadow-lg aspect-[4/3]">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="metadata"
          class="w-full h-full object-cover"
        >
          <source src="/arview.mp4" type="video/mp4" />
        </video>
      </div>

      <!-- TEXT (right) -->
      <div class="space-y-3 text-[1.12rem] leading-relaxed text-gray-700 dark:text-gray-300">
        <p>
          As severe weather events become more frequent, rescue operations are hindered by poor
          visibility, hazardous environments, and limited real-time information.
          <span class="font-semibold text-gray-900 dark:text-white">Tiger Flood Rescue</span>
          addresses these challenges by integrating autonomous drones, computer vision (CV), and
          augmented reality (AR) into a unified analysis platform.
        </p>
        <p>
          The system collects aerial imagery from drones and processes it in real time to detect
          points of interest, particularly
          <span class="font-semibold text-gray-900 dark:text-white">lost or abandoned dogs</span>,
          which are often overlooked during evacuations. Each detection is tagged with GPS
          coordinates to assist rescue teams.
        </p>
        <p>
          Results are visualized through an AR interface rendering a
          <span class="font-semibold text-gray-900 dark:text-white">3D sand table</span> that
          displays drone positions, flight paths, and identified targets, improving situational
          awareness during operations.
        </p>
        <p>
          By consolidating aerial data into a single interactive view, the platform enables faster,
          more informed decision-making in high-risk environments.
        </p>
      </div>
    </div>
  </div>
</div>

  <!-- Testimonials Widget *********** -->

  <Team
    id="roles"
    title="Meet the Team"
    subtitle="Senior Project Team Roles"
    team={[
      {
        name: 'Mason B.',
        job: 'Methodology Lead',
        image: {
          src: mason_b,
          alt: 'Mason B. Image',
        },
        description:
          "Ensures adherence to established project methodologies and manages the team's workflow and progress through the Jira board.",
      },
      {
        name: 'Dan C.',
        job: 'Hardware Manager',
        image: {
          src: default_profile,
          alt: 'Dan C. Image',
        },
        description:
          'Oversees storage, maintenance, and procedures for our project hardware, including drones, AR devices, and laptops.',
      },
      {
        name: 'Aiden K.',
        job: 'Project Manager',
        image: {
          src: default_profile,
          alt: 'Aiden K. Image',
        },
        description:
          'Leads overall project strategy, facilitates team decision-making, and ensures successful delivery of both RIT requirements and project milestones.',
      },
      {
        name: 'Kevin S.',
        job: 'Sponsor Communications Lead',
        image: {
          src: default_profile,
          alt: 'Kevin S. Image',
        },
        description:
          'Coordinates all communications between the team and BAE sponsors and develops weekly meeting agendas and quad charts.',
      }
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    id="sponsor"
    columns={3}
    items={[]}
    image={{
      src: bae_building,
      alt: 'A building with BAE Systems logo',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Sponsor</h2>
      <p>
        The sponsor for our project is BAE Systems, a defense, security, and aerospace company that delivers a range of
        products and services for air, land, and naval forces, as well as advanced electronics, security, and
        information technology solutions.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:opacity-5"></div>
    </Fragment>
  </Content>

  <!-- Weekly Schedule Widget **************** -->
  <Timetracking id="timetracking" />
</Layout>
